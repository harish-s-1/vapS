# ---- patS Backend (FastAPI) ----
ENV=development
API_PREFIX=/api/v1

# Security — generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database (Supabase / Postgres) — use the asyncpg driver
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/pats

# CORS
FRONTEND_ORIGIN=http://localhost:3000

# Integrations
GEMINI_API_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
VAPI_API_KEY=
