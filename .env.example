# ---- patS Frontend (Next.js) ----
# Public base URL of the FastAPI backend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Supabase (client-side, anon key only)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Google Sign-In — create an OAuth 2.0 Client ID (type: Web) in Google Cloud Console,
# add http://localhost:3000 (and your prod URL) to "Authorized JavaScript origins",
# then paste the client ID here. Leave blank to use the demo Google button.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Twilio (server-side) — for real SMS reminders from the Voice Assistant module.
# Find SID/Token in the Twilio Console; FROM is a Twilio phone number you own (E.164).
# Leave blank to run the reminder flow in demo mode (logged, not actually sent).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=


# Optional: a Messaging Service SID enables *scheduled* sends (15min–7days ahead).
TWILIO_MESSAGING_SERVICE_SID=
